# ── AI Providers ──────────────────────────────────────────────────────────────
# Used by both Breason (server-side) and ReDuck (via /api/reduck/process).
# Add at least one for AI features to work. All others are optional fallbacks.

GEMINI_API_KEY=          # aistudio.google.com — free, recommended primary
GROQ_API_KEY=            # console.groq.com — free, fast fallback
OPENROUTER_API_KEY=      # openrouter.ai — many models via one key
OPENAI_API_KEY=          # platform.openai.com — GPT-4o (paid)
ANTHROPIC_API_KEY=       # console.anthropic.com — Claude (paid)

# ── Resonance ─────────────────────────────────────────────────────────────────
TAVILY_API_KEY=          # tavily.com — live web search for trends (optional)
GEMINI_GROUNDING_ENABLED=true

# ── App URLs ──────────────────────────────────────────────────────────────────
# ReDuck is now built into Breason at /reduck — this env var is no longer needed
# but kept for backward compat with any external references.
NEXT_PUBLIC_REDUCK_URL=http://localhost:3000/reduck
