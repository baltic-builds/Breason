# AI Providers
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Resonance / Trends
TAVILY_API_KEY=

# Optional Feature Flags
NEXT_PUBLIC_ENABLE_AB_PROMPTS=true
NEXT_PUBLIC_DEFAULT_PROMPT_VERSION=reduck/lead-magnet@1

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI Pipeline - free-tier first
# OpenAI runs first only when these guards are explicitly enabled.
# Enable only after the OpenAI org owner opts into input/output sharing and the dashboard says the project is enrolled for complimentary daily tokens.
OPENAI_ENABLED=true
OPENAI_FREE_ONLY=true
OPENAI_DATA_SHARING_CONFIRMED=false
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_DAILY_TOKEN_LIMIT=200000
OPENAI_MAX_OUTPUT_TOKENS=2200
OPENAI_TIMEOUT_MS=25000

GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_MS=22000
GEMINI_MAX_OUTPUT_TOKENS=2600

GROQ_QWEN_MODEL=qwen/qwen3-32b
GROQ_LLAMA_MODEL=llama-3.3-70b-versatile
GROQ_COMPOUND_MODEL=groq/compound
GROQ_TIMEOUT_MS=22000
GROQ_COMPOUND_TIMEOUT_MS=28000
GROQ_MAX_OUTPUT_TOKENS=2600

OPENROUTER_ENABLED=true
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_TIMEOUT_MS=28000
OPENROUTER_MAX_OUTPUT_TOKENS=2600

AI_TEMPERATURE=0.35
AI_CIRCUIT_FAIL_THRESHOLD=2
AI_CIRCUIT_RESET_MS=60000
