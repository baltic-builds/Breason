{
  "name": "breason",
  "private": true,
  "version": "0.4.0",
  "packageManager": "npm@10.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:breason": "npm run dev --workspace=breason-app",
